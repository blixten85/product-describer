{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "schedule:daily",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMajorReleases",
    ":rebaseStalePrs"
  ],
  "timezone": "Europe/Stockholm",
  "labels": [
    "dependencies",
    "renovate"
  ],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "* 2-4 * * 2"
    ]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ]
  },
  "packageRules": [
    {
      "description": "Automerge patch updates on their own (kept out of any non-major group)",
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions"
    }
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10,
  "schedule": [
    "* 2-4 * * 2"
  ],
  "updateNotScheduled": false
}
