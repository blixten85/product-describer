# Container/host
TZ=Europe/Stockholm
PUID=1000
PGID=1000

# AI providers — at least one is required. Keys can also be entered later
# via the web UI settings panel, which writes them under CONFIG_DIR/credentials/.
# Gemini has a free tier (Google AI Studio); Anthropic, OpenAI and Azure
# OpenAI are all billed pay-per-use regardless of any consumer subscription
# (Claude Pro / ChatGPT Plus / Copilot) you may also have — those
# subscriptions have no API of their own.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
AZURE_OPENAI_API_KEY=
# Azure OpenAI also needs an endpoint + deployment name, which (since
# they're not secrets) can only be set via the web UI settings panel.

# Required. Saving a key under the web UI's Inställningar panel encrypts it
# at rest, so this must be set before starting the container or saving a key
# will fail with "Missing encryption key". Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROVIDER_CONFIG_MASTER_KEY=

# Required. Signs the login session cookie — must stay the same across
# restarts or everyone gets logged out. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Where provider keys and the failover order are stored (mounted volume).
CONFIG_DIR=config

# How often (seconds) the background watcher checks for paused jobs whose
# provider quota has reset, so they can resume automatically.
RESUME_CHECK_INTERVAL=120

# Finished jobs (done/error) older than this many days are purged, with their
# uploaded input and output files, so disk/memory don't grow forever. 0 = keep.
JOB_RETENTION_DAYS=30

# Set to 0/false only for local dev over plain HTTP — otherwise the session
# cookie is marked Secure and never sent over an unencrypted connection.
SESSION_COOKIE_SECURE=1

# Brute-force throttle on /login: after this many failed attempts per
# email+IP within the window (seconds), further attempts are rejected (429).
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=900

# Sync mode (set SYNC_ENABLED=true to enable the background worker that
# polls scraper for products without descriptions)
SYNC_ENABLED=false
SCRAPER_URL=http://scraper:8000
SYNC_INTERVAL=300

# Name of the scraper compose stack's docker network. Default assumes the
# scraper repo is checked out into a directory called `scraper` (which makes
# docker-compose name the network `scraper_default`). Find yours with:
#   docker inspect scraper -f '{{range $k,$v := .NetworkSettings.Networks}}{{$k}} {{end}}'
SCRAPER_NETWORK=scraper_default

# Optional. Fine-grained GitHub PAT scoped to this repo with "Issues: Write"
# only. If set, an unhandled error automatically opens a GitHub issue tagged
# @claude (so the repo's existing Claude Code Action picks it up) instead of
# just failing silently. Sensitive data (API keys/tokens, emails, file
# content, paths with usernames) is redacted before anything is sent.
GITHUB_ERROR_REPORT_TOKEN=
